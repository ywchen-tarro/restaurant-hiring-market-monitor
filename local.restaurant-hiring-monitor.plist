<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>local.restaurant-hiring-monitor</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__PROJECT_PATH__/run.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__PROJECT_PATH__</string>

    <!-- Daily at 09:00 local time. Daily cadence keeps uscanyin's
         relative-date dates aligned (otherwise "1 hour ago" posts from
         the day before a scrape land on the wrong day). -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key><integer>9</integer>
        <key>Minute</key><integer>0</integer>
    </dict>

    <!-- Fallback every 6 hours. run.sh skips quickly when data is already
         current, so this catches missed calendar triggers caused by sleep. -->
    <key>StartInterval</key>
    <integer>21600</integer>

    <key>StandardOutPath</key>
    <string>__PROJECT_PATH__/logs/scraper.log</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_PATH__/logs/scraper_error.log</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
